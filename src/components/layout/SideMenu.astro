---
import { facility } from '../../data/facility';
---

<div class="nav" id="nav" aria-hidden="true">
  <div class="nav-inner">
    <div class="nav-col">
      <h4>Navigation — 案内</h4>
      <ul class="nav-list">
        {facility.navServices.map((s, i) => (
          <li class={s.id === 'english' ? 'nav-english-site' : undefined}>
            <a href={s.href}>
              <span><span class="num">{String(i + 1).padStart(2, '0')}</span>{s.label}</span>
              <span class="en">{s.labelEn}</span>
            </a>
          </li>
        ))}
        <li class="nav-english-site"><a href="#"><span>English Site</span><span class="en">→</span></a></li>
      </ul>
    </div>

    <div class="nav-col nav-right">
      <div>
        <h4>Featured — おすすめ</h4>
        <a href="#fishing" class="nav-card">
          <div class="thumb"></div>
          <div>
            <h5>渓流釣り · つかみ捕り</h5>
            <p>お子様から大人まで · 手ぶらでOK</p>
          </div>
        </a>
        <a href="#bbq" class="nav-card" style="margin-top:16px;">
          <div class="thumb" style="background:repeating-linear-gradient(45deg, rgba(255,180,100,0.2) 0 6px, transparent 6px 12px), linear-gradient(135deg, rgba(255,140,60,0.3), rgba(11,20,25,0.6));"></div>
          <div>
            <h5>BBQハウス · 炭火焼き</h5>
            <p>屋根付き · 手ぶらプランあり</p>
          </div>
        </a>
      </div>

      <dl class="nav-info">
        <div>
          <dt>Address</dt>
          <dd set:html={`${facility.address.line1}<br/>${facility.address.line2}`} />
        </div>
        <div>
          <dt>Hours</dt>
          <dd set:html={`${facility.hours.open} — ${facility.hours.close}<br/>定休日 ${facility.hours.closed}`} />
        </div>
        <div>
          <dt>Reservations</dt>
          <dd><a href={`tel:${facility.contact.tel}`} style="color:inherit;text-decoration:none;">{facility.contact.telDisplay}</a></dd>
        </div>
        <div>
          <dt>Parking</dt>
          <dd>{facility.parking}</dd>
        </div>
      </dl>
    </div>
  </div>
</div>

<script>
  const menuBtn = document.getElementById('menuBtn');
  const nav = document.getElementById('nav');
  function toggleNav(force?: boolean) {
    const open = force ?? !nav!.classList.contains('open');
    nav!.classList.toggle('open', open);
    nav!.setAttribute('aria-hidden', String(!open));
    menuBtn!.setAttribute('aria-expanded', String(open));
    document.body.style.overflow = open ? 'hidden' : '';
  }
  menuBtn!.addEventListener('click', () => toggleNav());
  document.addEventListener('keydown', e => { if (e.key === 'Escape') toggleNav(false); });
  nav!.addEventListener('click', e => { if (e.target === nav) toggleNav(false); });
</script>

<style is:global>
  .nav {
    position: fixed; inset: 0; z-index: 100;
    background: rgba(8, 16, 20, 0.94);
    backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);
    opacity: 0; pointer-events: none; transition: opacity .5s ease;
  }
  .nav.open { opacity: 1; pointer-events: auto; }
  .nav-inner {
    height: 100%; display: grid; grid-template-columns: 1fr 1fr;
    padding: 120px 80px 60px; gap: 80px;
  }
  .nav-col h4 {
    font-family: var(--mono); font-size: 10px; letter-spacing: 0.35em;
    color: var(--accent); text-transform: uppercase; margin: 0 0 40px 0;
    font-weight: 400; display: flex; align-items: center; gap: 14px;
  }
  .nav-col h4::before {
    content: ""; display: block; width: 24px; height: 1px; background: var(--accent);
  }
  .nav-list { list-style: none; padding: 0; margin: 0; }
  .nav-list li {
    padding: 14px 0; border-bottom: 1px solid var(--line);
    opacity: 0; transform: translateY(20px); transition: opacity .6s ease, transform .6s ease;
  }
  .nav.open .nav-list li { opacity: 1; transform: translateY(0); }
  .nav.open .nav-list li:nth-child(1) { transition-delay: .15s; }
  .nav.open .nav-list li:nth-child(2) { transition-delay: .22s; }
  .nav.open .nav-list li:nth-child(3) { transition-delay: .29s; }
  .nav.open .nav-list li:nth-child(4) { transition-delay: .36s; }
  .nav.open .nav-list li:nth-child(5) { transition-delay: .43s; }
  .nav.open .nav-list li:nth-child(6) { transition-delay: .50s; }
  .nav.open .nav-list li:nth-child(7) { transition-delay: .57s; }
  .nav-list a {
    display: flex; align-items: baseline; justify-content: space-between; gap: 24px;
    font-family: var(--serif-jp); font-weight: 300; font-size: 38px; letter-spacing: 0.18em;
    color: var(--ink); transition: color .3s ease, padding-left .3s ease;
  }
  .nav-list a:hover { color: var(--accent); padding-left: 12px; }
  .nav-list a .en {
    font-family: var(--serif-en); font-style: italic; font-weight: 300; font-size: 14px;
    letter-spacing: 0.3em; color: var(--ink-faint); text-transform: uppercase;
  }
  .nav-list a .num {
    font-family: var(--mono); font-size: 11px; letter-spacing: 0.2em;
    color: var(--accent); margin-right: 8px; vertical-align: 4px;
  }
  .nav-right { display: flex; flex-direction: column; gap: 48px; }
  .nav-card {
    padding: 32px; border: 1px solid var(--line); background: rgba(255,255,255,0.02);
    display: grid; grid-template-columns: 96px 1fr; gap: 28px; align-items: center;
    transition: background .3s ease, border-color .3s ease;
  }
  .nav-card:hover { background: rgba(156,199,212,0.06); border-color: rgba(156,199,212,0.4); }
  .nav-card .thumb {
    width: 96px; height: 96px;
    background: repeating-linear-gradient(45deg, rgba(156,199,212,0.18) 0 6px, transparent 6px 12px),
                linear-gradient(135deg, rgba(156,199,212,0.15), rgba(11,20,25,0.6));
    border: 1px solid var(--line);
  }
  .nav-card h5 { margin: 0 0 8px 0; font-family: var(--serif-jp); font-weight: 400; font-size: 17px; letter-spacing: 0.18em; }
  .nav-card p { margin: 0; font-family: var(--serif-en); font-style: italic; font-size: 12px; letter-spacing: 0.25em; color: var(--ink-faint); text-transform: uppercase; }
  .nav-info {
    margin-top: auto; display: grid; grid-template-columns: 1fr 1fr; gap: 24px;
    padding-top: 32px; border-top: 1px solid var(--line);
  }
  .nav-info dt { font-family: var(--mono); font-size: 9px; letter-spacing: 0.3em; color: var(--ink-faint); text-transform: uppercase; margin-bottom: 6px; }
  .nav-info dd { font-family: var(--serif-jp); font-weight: 300; font-size: 14px; letter-spacing: 0.14em; color: var(--ink); margin: 0; }
  .nav-english-site { display: none; }
  @media (max-width: 640px) { .nav-english-site { display: list-item; } }
</style>
