---
import { facility } from '../../data/facility';
import { translations } from '../../data/translations';
---

<header class="topbar">
  <div style="display:flex; align-items:flex-start;">
    <button class="hamburger" id="menuBtn" aria-label="メニューを開く" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
    <span class="menu-label">
      <span data-lang-ja>{translations.menuLabel.ja}</span>
      <span data-lang-en>{translations.menuLabel.en}</span>
    </span>
  </div>

  <div class="logo">
    <span class="logo-mark">{facility.name}</span>
    <span class="logo-sub">{facility.nameEn} · {facility.subtitleEn}</span>
  </div>

  <div class="topbar-right">
    <div class="lang-toggle">
      <button class="lang-btn" data-lang-btn="ja">JA</button>
      <span class="sep">/</span>
      <button class="lang-btn" data-lang-btn="en">EN</button>
    </div>
    <a href={`tel:${facility.contact.tel}`} class="phone">
      <small>Reservations</small>
      {facility.contact.telDisplay}
    </a>
  </div>
</header>

<script>
  const topbar = document.querySelector('.topbar');
  const TOPBAR_THRESHOLD = 80;
  let topbarTicking = false;

  function updateTopbar() {
    if (topbar) {
      topbar.classList.toggle('scrolled', window.scrollY > TOPBAR_THRESHOLD);
    }
    topbarTicking = false;
  }

  window.addEventListener('scroll', () => {
    if (!topbarTicking) {
      requestAnimationFrame(updateTopbar);
      topbarTicking = true;
    }
  }, { passive: true });

  updateTopbar();

  const ctasEl = document.querySelector('.ctas');
  const mobileCtasEl = document.querySelector('.mobile-ctas');
  const CTA_THRESHOLD = window.innerHeight * 0.8;
  let ctaTicking = false;

  function updateCTAs() {
    const scrolled = window.scrollY > CTA_THRESHOLD;
    if (ctasEl) ctasEl.classList.toggle('cta-compact', scrolled);
    if (mobileCtasEl) mobileCtasEl.classList.toggle('cta-compact', scrolled);
    ctaTicking = false;
  }

  window.addEventListener('scroll', () => {
    if (!ctaTicking) { requestAnimationFrame(updateCTAs); ctaTicking = true; }
  }, { passive: true });

  updateCTAs();

  document.querySelectorAll('.lang-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const lang = btn.getAttribute('data-lang-btn');
      if (lang) {
        document.documentElement.setAttribute('data-lang', lang);
        localStorage.setItem('sakana-lang', lang);
      }
    });
  });
</script>

<style is:global>
  .topbar {
    position: fixed; top: 0; left: 0; right: 0;
    padding: 32px 40px;
    display: flex; align-items: flex-start; justify-content: space-between;
    z-index: 50;
    transition: background 0.4s ease, backdrop-filter 0.4s ease, border-bottom-color 0.4s ease, color 0.4s ease;
    border-bottom: 1px solid transparent;
  }
  .topbar.scrolled {
    background: rgba(244, 245, 241, 0.92);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom-color: rgba(26, 33, 38, 0.12);
  }
  .topbar.scrolled .logo-mark,
  .topbar.scrolled .phone,
  .topbar.scrolled .menu-label { color: #1a2126; }
  .topbar.scrolled .logo-sub,
  .topbar.scrolled .lang-toggle,
  .topbar.scrolled .lang-btn,
  .topbar.scrolled .phone small { color: rgba(26, 33, 38, 0.55); }
  html[data-lang="ja"] .topbar.scrolled .lang-btn[data-lang-btn="ja"],
  html[data-lang="en"] .topbar.scrolled .lang-btn[data-lang-btn="en"] { color: #1a2126; }
  .topbar.scrolled .hamburger span { background: #1a2126; }

  @media (max-width: 768px) { .topbar { padding: 24px 20px; } }

  .hamburger {
    width: 44px; height: 44px;
    display: grid; place-items: center;
    position: relative;
    transition: transform .3s ease;
  }
  .hamburger:hover { transform: scale(1.08); }
  .hamburger span {
    position: absolute; left: 10px; right: 10px;
    height: 1.5px; background: var(--ink);
    transition: transform .35s ease, opacity .25s ease, top .35s ease, background 0.4s ease;
  }
  .hamburger span:nth-child(1) { top: 16px; }
  .hamburger span:nth-child(2) { top: 22px; width: 18px; right: auto; left: 10px; }
  .hamburger span:nth-child(3) { top: 28px; }
  .hamburger[aria-expanded="true"] span:nth-child(1) { top: 22px; transform: rotate(45deg); }
  .hamburger[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .hamburger[aria-expanded="true"] span:nth-child(3) { top: 22px; transform: rotate(-45deg); }

  .menu-label {
    font-family: var(--mono); font-size: 10px; letter-spacing: 0.25em;
    color: var(--ink-dim); margin-left: 14px; transform: translateY(14px);
  }
  .logo { text-align: center; line-height: 1; }
  .logo-mark {
    display: block; font-family: var(--serif-jp); font-weight: 400;
    font-size: 28px; letter-spacing: 0.6em; color: var(--ink); padding-left: 0.6em;
  }
  .logo-sub {
    display: block; margin-top: 10px; font-family: var(--serif-en); font-style: italic;
    font-weight: 300; font-size: 11px; letter-spacing: 0.42em;
    color: var(--ink-dim); padding-left: 0.42em; text-transform: uppercase;
  }
  .topbar-right { display: flex; align-items: center; gap: 20px; }
  .lang-toggle {
    font-family: var(--mono); font-size: 10px; letter-spacing: 0.25em;
    color: var(--ink-dim); display: flex; align-items: center; gap: 4px;
  }
  .lang-btn {
    padding: 4px 6px; cursor: pointer;
    font-family: var(--mono); font-size: 10px; letter-spacing: 0.25em;
    color: var(--ink-dim); background: none; border: none;
    transition: color 0.3s ease;
  }
  .lang-btn:hover { color: var(--ink); }
  html[data-lang="ja"] .lang-btn[data-lang-btn="ja"],
  html[data-lang="en"] .lang-btn[data-lang-btn="en"] {
    color: var(--ink); font-weight: 500;
  }
  .lang-toggle .sep { color: var(--ink-faint); }
  .phone {
    font-family: var(--serif-en); font-size: 15px; letter-spacing: 0.12em; color: var(--ink);
  }
  .phone small {
    display: block; font-family: var(--mono); font-size: 9px; letter-spacing: 0.3em;
    color: var(--ink-faint); margin-bottom: 2px; text-transform: uppercase;
  }

  @media (max-width: 640px) {
    .topbar-right .phone { display: none; }
    .topbar { padding: 16px 16px; }
    .menu-label { display: none; }
    .logo-mark { font-size: 16px; letter-spacing: 0.25em; padding-left: 0.25em; }
    .logo-sub { font-size: 7px; letter-spacing: 0.25em; white-space: nowrap; }
  }
</style>
