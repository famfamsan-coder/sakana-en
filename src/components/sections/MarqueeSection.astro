---
import type { MarqueeData } from '../../data/marquees';

interface Props {
  data: MarqueeData;
  index: number;
  isAlt?: boolean;
}

const { data, index, isAlt = false } = Astro.props;
const layout = data.mobileLayout;
---

<article class:list={['mq-block', { alt: isAlt }]}>
  <header class="mq-head reveal">
    <div class="mq-chapter">
      <span class="mq-rule"></span>
      <span>{data.chapterLabel}</span>
      <span class="mq-num">{data.chapterNum}</span>
    </div>
    <div class="mq-title-row">
      <h3 class="mq-title-en">{data.titleEn}<em>.</em></h3>
      <p class="mq-title-ja">{data.titleJa}</p>
    </div>
    <div class="mq-body">
      <p set:html={data.description.replace(/\n/g, '<br/>')} />
      <a href={data.readMoreHref} class="mq-more">{data.readMoreLabel} <span class="arrow">→</span></a>
    </div>
  </header>

  <div class="marquee-wrapper" data-dir={data.direction} style={`--duration: ${data.duration};`}>
    <div class:list={['marquee-track', { reverse: data.direction === 'right' }]}>
      {data.images.map((img, i) => (
        <figure class="mq-tile">
          <img src={img.src} alt={img.alt} loading={index === 0 && i < 2 ? 'eager' : 'lazy'} />
          <figcaption>{img.caption}</figcaption>
        </figure>
      ))}
      {data.images.map((img) => (
        <figure class="mq-tile" aria-hidden="true">
          <img src={img.src} alt="" loading="lazy" />
          <figcaption>{img.caption}</figcaption>
        </figure>
      ))}
    </div>
  </div>

  <div class="mq-mobile-grid reveal" data-layout={layout}>
    {layout === 'hero-with-two' && (
      <>
        <figure class="mg-tile mg-hero">
          <img src={data.images[2].src} alt={data.images[2].alt} loading="lazy" />
          <figcaption>{data.images[2].caption}</figcaption>
        </figure>
        <figure class="mg-tile mg-sub">
          <img src={data.images[0].src} alt={data.images[0].alt} loading="lazy" />
          <figcaption>{data.images[0].caption}</figcaption>
        </figure>
        <figure class="mg-tile mg-sub">
          <img src={data.images[1].src} alt={data.images[1].alt} loading="lazy" />
          <figcaption>{data.images[1].caption}</figcaption>
        </figure>
      </>
    )}
    {layout === 'asymmetric-pair' && (
      <>
        <figure class="mg-tile mg-tall">
          <img src={data.images[1].src} alt={data.images[1].alt} loading="lazy" />
          <figcaption>{data.images[1].caption}</figcaption>
        </figure>
        <figure class="mg-tile mg-half">
          <img src={data.images[2].src} alt={data.images[2].alt} loading="lazy" />
          <figcaption>{data.images[2].caption}</figcaption>
        </figure>
        <figure class="mg-tile mg-half">
          <img src={data.images[3].src} alt={data.images[3].alt} loading="lazy" />
          <figcaption>{data.images[3].caption}</figcaption>
        </figure>
      </>
    )}
    {layout === 'single-hero' && (
      <figure class="mg-tile mg-full">
        <img src={data.images[0].src} alt={data.images[0].alt} loading="lazy" />
        <figcaption>{data.images[0].caption}</figcaption>
      </figure>
    )}
  </div>
</article>

<style is:global>
  .mq-sections {
    background: #f4f5f1;
    color: #1a2126;
    padding: 40px 0 140px;
  }
  .mq-block {
    padding: 80px 0 0;
    position: relative;
  }
  .mq-block + .mq-block {
    border-top: 1px solid rgba(26,33,38,0.1);
    margin-top: 80px;
  }

  .mq-head {
    max-width: 1320px;
    margin: 0 auto 64px;
    padding: 0 80px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: end;
  }
  .mq-chapter {
    grid-column: 1 / -1;
    display: flex; align-items: center; gap: 16px;
    font-family: var(--mono); font-size: 10px; letter-spacing: 0.35em;
    color: var(--accent-deep); text-transform: uppercase;
    margin-bottom: 8px;
  }
  .mq-chapter .mq-rule {
    width: 48px; height: 1px; background: var(--accent-deep);
  }
  .mq-chapter .mq-num { margin-left: auto; color: rgba(26,33,38,0.45); }

  .mq-title-row {
    display: flex; align-items: baseline; gap: 32px;
  }
  .mq-title-en {
    margin: 0;
    font-family: var(--serif-en);
    font-weight: 300;
    font-size: clamp(72px, 11vw, 168px);
    letter-spacing: 0.02em;
    line-height: 0.9;
    color: #1a2126;
  }
  .mq-title-en em {
    font-style: italic; color: var(--accent-deep);
    font-size: 0.5em; letter-spacing: 0; vertical-align: 0.35em;
  }
  .mq-title-ja {
    margin: 0 0 16px 0;
    font-family: var(--serif-jp);
    font-weight: 300;
    font-size: 18px;
    letter-spacing: 0.16em;
    color: rgba(26,33,38,0.7);
    white-space: nowrap;
  }
  .mq-body {
    padding-bottom: 12px;
  }
  .mq-body p {
    margin: 0 0 24px 0;
    font-family: var(--serif-jp);
    font-weight: 300;
    font-size: 14px;
    line-height: 2.0;
    letter-spacing: 0.1em;
    color: rgba(26,33,38,0.72);
  }
  .mq-more {
    display: inline-flex; align-items: center; gap: 12px;
    font-family: var(--mono); font-size: 11px; letter-spacing: 0.3em;
    color: #1a2126; text-transform: uppercase;
    padding-bottom: 4px;
    border-bottom: 1px solid transparent;
    transition: border-color .3s ease, gap .3s ease, color .3s ease;
  }
  .mq-more .arrow { font-family: var(--serif-en); font-size: 14px; transition: transform .3s ease; }
  .mq-more:hover { color: var(--accent-deep); gap: 20px; border-color: var(--accent-deep); }
  .mq-more:hover .arrow { transform: translateX(4px); }

  .marquee-wrapper {
    width: 100%;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(to right, transparent, #000 3%, #000 97%, transparent);
            mask-image: linear-gradient(to right, transparent, #000 3%, #000 97%, transparent);
  }
  .marquee-track {
    display: flex;
    gap: 24px;
    width: max-content;
    animation: mqScroll var(--duration, 70s) linear infinite;
  }
  .marquee-track.reverse { animation-direction: reverse; }
  .marquee-wrapper:hover .marquee-track { animation-play-state: paused; }

  .mq-tile {
    flex: 0 0 auto;
    width: 60vw;
    max-width: 900px;
    margin: 0;
    overflow: hidden;
  }
  .mq-tile img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    display: block;
    transition: transform 0.8s ease;
  }
  .mq-tile:hover img { transform: scale(1.02); }
  .mq-tile figcaption {
    font-family: var(--mono); font-size: 11px; letter-spacing: 0.2em;
    color: rgba(26,33,38,0.45); text-transform: uppercase;
    margin-top: 16px; padding-left: 4px;
  }

  @keyframes mqScroll {
    from { transform: translateX(0); }
    to   { transform: translateX(calc(-50% - 12px)); }
  }

  .mq-mobile-grid {
    display: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-track { animation: none; }
  }

  @media (max-width: 1024px) {
    .mq-head { padding: 0 40px; grid-template-columns: 1fr; gap: 24px; margin-bottom: 48px; }
    .mq-title-row { flex-direction: column; align-items: flex-start; gap: 12px; }
    .mq-title-en { font-size: 72px; }
    .mq-title-ja { white-space: normal; font-size: 14px; }
    .mq-tile { width: 70vw; max-width: 700px; }
  }

  @media (max-width: 640px) {
    .mq-sections { padding: 80px 0 100px; }
    .mq-block { padding: 48px 0; }
    .mq-head { padding: 0 24px; margin-bottom: 32px; }
    .mq-title-en { font-size: 48px; letter-spacing: 0.04em; }
    .mq-title-ja { font-size: 11px; letter-spacing: 0.25em; }
    .mq-body p { font-size: 13px; line-height: 1.9; letter-spacing: 0.06em; }

    .marquee-wrapper { display: none; }

    .mq-mobile-grid {
      display: grid;
      gap: 12px;
      padding: 0 16px;
    }

    .mq-mobile-grid[data-layout="hero-with-two"] {
      grid-template-columns: 1fr 1fr;
    }
    .mq-mobile-grid[data-layout="hero-with-two"] .mg-hero {
      grid-column: 1 / -1;
    }
    .mq-mobile-grid[data-layout="hero-with-two"] .mg-hero img {
      aspect-ratio: 4 / 3;
    }
    .mq-mobile-grid[data-layout="hero-with-two"] .mg-sub img {
      aspect-ratio: 1 / 1;
    }

    .mq-mobile-grid[data-layout="asymmetric-pair"] {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 1fr 1fr;
    }
    .mq-mobile-grid[data-layout="asymmetric-pair"] .mg-tall {
      grid-row: 1 / -1;
    }
    .mq-mobile-grid[data-layout="asymmetric-pair"] .mg-tall img {
      aspect-ratio: 3 / 4;
      height: 100%;
    }
    .mq-mobile-grid[data-layout="asymmetric-pair"] .mg-half img {
      aspect-ratio: 4 / 3;
    }

    .mq-mobile-grid[data-layout="single-hero"] .mg-full img {
      aspect-ratio: 4 / 5;
    }

    .mg-tile {
      position: relative;
      overflow: hidden;
      margin: 0;
    }
    .mg-tile img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .mg-tile figcaption {
      position: absolute;
      bottom: 12px;
      left: 12px;
      padding: 4px 10px;
      background: rgba(11, 20, 25, 0.72);
      color: rgba(255, 255, 255, 0.9);
      font-family: var(--mono);
      font-size: 9px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
    }
  }
</style>
