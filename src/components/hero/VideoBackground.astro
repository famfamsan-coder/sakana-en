---
const videos = [
  '/videos/hero-01.mp4',
  '/videos/hero-02.mp4',
  '/videos/hero-03.mp4',
  '/videos/hero-04.mp4',
  '/videos/hero-05.mp4',
  '/videos/hero-06.mp4',
];
---

<div class="video-stage">
  {videos.map((src, i) => (
    <video
      class:list={['hero-video', { active: i === 0 }]}
      src={src}
      muted
      playsinline
      preload="auto"
      data-index={i}
    />
  ))}
</div>

<script>
  (function initVideos() {
    const isPCish = window.matchMedia('(min-width: 1025px)').matches;
    if (!isPCish) {
      document.querySelectorAll('.hero-video').forEach(function(v) {
        (v as HTMLVideoElement).removeAttribute('src');
        (v as HTMLVideoElement).load();
      });
      return;
    }

    const videos = Array.from(document.querySelectorAll('.hero-video')) as HTMLVideoElement[];
    if (videos.length === 0) return;

    let currentIndex = 0;

    function playNext() {
      const current = videos[currentIndex];
      const nextIndex = (currentIndex + 1) % videos.length;
      const next = videos[nextIndex];

      next.currentTime = 0;
      next.play().catch(function(err) { console.warn('video play blocked:', err); });
      next.classList.add('active');

      setTimeout(function() {
        current.classList.remove('active');
        setTimeout(function() {
          current.pause();
          current.currentTime = 0;
        }, 1500);
      }, 600);

      currentIndex = nextIndex;
    }

    videos.forEach(function(v, idx) {
      v.addEventListener('ended', function() {
        if (idx === currentIndex) playNext();
      });
      v.addEventListener('error', function(e) {
        console.error('video load error:', v.src, e);
      });
    });

    const first = videos[0];
    function start() {
      first.play().catch(function(err) { console.warn('initial play blocked:', err); });
    }

    if (first.readyState >= 2) {
      start();
    } else {
      first.addEventListener('loadeddata', start, { once: true });
      first.addEventListener('canplay', start, { once: true });
    }

    videos.slice(1).forEach(function(v) {
      if (v.readyState < 2) v.load();
    });
  })();
</script>

<style is:global>
  .video-stage {
    position: absolute; inset: 0;
    overflow: hidden;
    background: #0b1419;
  }

  .hero-video {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.6s ease;
    will-change: opacity;
  }
  .hero-video.active { opacity: 1; }

  @media (max-width: 1024px) {
    .video-stage { display: none !important; }
  }
</style>
