---
import { facility } from '../../data/facility';
import VideoBackground from './VideoBackground.astro';
import MobilePoster from './MobilePoster.astro';
import HeroCopy from './HeroCopy.astro';
---

<section class="hero">
  <VideoBackground />
  <MobilePoster />

  <div class="overlay"></div>

  <a href="#" class="vguests">For International Guests — English Site</a>

  <nav class="sns" aria-label="ソーシャルメディア">
    <a href="#" aria-label="Instagram"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.8" fill="currentColor" stroke="none"/></svg></a>
    <a href={facility.sns.x.url} aria-label="X (Twitter)"><svg viewBox="0 0 24 24"><path d="M4 4l16 16M20 4L4 20"/></svg></a>
    <a href="#" aria-label="YouTube"><svg viewBox="0 0 24 24"><rect x="2.5" y="6" width="19" height="12" rx="3"/><path d="M10 9.5l4.5 2.5L10 14.5z" fill="currentColor" stroke="none"/></svg></a>
    <a href="#" aria-label="Facebook"><svg viewBox="0 0 24 24"><path d="M14 7h2.5V4H14c-2 0-3 1.2-3 3v2H9v3h2v9h3v-9h2.5l.5-3H14V7.5c0-.3.2-.5.5-.5z"/></svg></a>
  </nav>

  <aside class="ctas" aria-label="予約・お知らせ">
    <a href={`tel:${facility.contact.tel}`} class="cta primary">
      <span class="dot"></span>
      <span class="en">Reserve</span>
      <span class="jp">予約</span>
    </a>
    <a href="#" class="cta">
      <span class="dot"></span>
      <span class="en">News</span>
      <span class="jp">お知らせ</span>
    </a>
  </aside>

  <HeroCopy />

  <div class="bottombar">
    <div class="scroll-cue">
      <span>Scroll</span>
      <span class="line"></span>
    </div>
  </div>

  <div class="mobile-ctas">
    <a href={`tel:${facility.contact.tel}`} class="primary">予約</a>
    <a href="#">お知らせ</a>
  </div>
</section>

<style is:global>
  .hero {
    position: relative;
    height: 100vh;
    min-height: 680px;
    overflow: hidden;
    background: #000;
  }

  .overlay {
    position: absolute; inset: 0;
    z-index: 3;
    background: linear-gradient(180deg,
      rgba(0,0,0,0.45) 0%,
      rgba(0,0,0,0.30) 18%,
      rgba(0,0,0,0.20) 35%,
      rgba(0,0,0,0.05) 55%,
      rgba(0,0,0,0.15) 85%,
      rgba(0,0,0,0.35) 100%
    );
    pointer-events: none;
  }

  .vguests {
    position: fixed; left: 24px; top: 50%;
    transform: translateY(-50%);
    writing-mode: vertical-rl;
    font-family: var(--serif-en);
    font-style: italic;
    font-weight: 300;
    font-size: 13px;
    letter-spacing: 0.38em;
    color: var(--ink-dim);
    z-index: 15;
    transition: color .3s ease;
  }
  .vguests:hover { color: var(--ink); }
  .vguests::before {
    content: "";
    position: absolute;
    top: -44px; left: 50%;
    width: 1px; height: 32px;
    background: var(--ink-faint);
  }

  .sns {
    position: fixed; right: 26px; top: 50%;
    transform: translateY(-50%);
    display: flex; flex-direction: column; gap: 22px;
    z-index: 15;
  }
  .sns a {
    width: 20px; height: 20px;
    display: grid; place-items: center;
    color: var(--ink-dim);
    transition: color .25s ease, transform .25s ease;
  }
  .sns a:hover { color: var(--ink); transform: translateY(-2px); }
  .sns svg { width: 16px; height: 16px; stroke: currentColor; fill: none; stroke-width: 1.4; }
  .sns::before, .sns::after {
    content: ""; height: 40px; width: 1px;
    background: var(--ink-faint);
    margin: 0 auto;
  }

  .ctas {
    position: fixed; right: 0; top: 50%;
    transform: translateY(-50%) translateX(0);
    display: flex; flex-direction: column;
    z-index: 16;
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  .ctas.cta-compact {
    opacity: 0;
    pointer-events: none;
    transform: translateY(-50%) translateX(20px);
  }
  .cta {
    width: 56px; height: 240px;
    writing-mode: vertical-rl;
    display: flex; align-items: center; justify-content: center;
    gap: 14px;
    padding: 24px 0;
    background: rgba(11, 20, 25, 0.55);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-left: 1px solid var(--line);
    border-top: 1px solid var(--line);
    color: var(--ink);
    transition: background .3s ease, width .3s ease;
    position: relative;
  }
  .cta:last-child { border-bottom: 1px solid var(--line); }
  .cta:hover { background: rgba(156, 199, 212, 0.85); color: var(--deep); }
  .cta .en {
    font-family: var(--serif-en);
    font-size: 15px;
    letter-spacing: 0.42em;
    text-transform: uppercase;
  }
  .cta .jp {
    font-family: var(--serif-jp);
    font-size: 12px;
    letter-spacing: 0.4em;
  }
  .cta .dot {
    width: 4px; height: 4px; border-radius: 50%;
    background: var(--accent);
    transition: background .3s ease;
  }
  .cta:hover .dot { background: var(--deep); }
  .cta.primary {
    background: rgba(156, 199, 212, 0.92);
    color: var(--deep);
  }
  .cta.primary .dot { background: var(--deep); }
  .cta.primary:hover { background: var(--ink); }

  .bottombar {
    position: absolute; bottom: 0; left: 0; right: 72px;
    display: flex; align-items: flex-end; justify-content: center;
    padding: 0 40px 28px 40px;
    z-index: 12;
    pointer-events: none;
  }
  .bottombar > * { pointer-events: auto; }

  .scroll-cue {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.3em;
    color: var(--ink-dim);
    text-transform: uppercase;
    display: flex; flex-direction: column; align-items: center; gap: 14px;
  }
  .scroll-cue .line {
    width: 1px; height: 54px;
    background: linear-gradient(180deg, var(--ink-faint) 0%, var(--ink) 100%);
    position: relative; overflow: hidden;
  }
  .scroll-cue .line::after {
    content: ""; position: absolute; top: -40px; left: 0; right: 0;
    height: 40px; background: var(--accent);
    animation: scrollPulse 2.4s ease-in-out infinite;
  }
  @keyframes scrollPulse {
    0%   { transform: translateY(0); }
    100% { transform: translateY(94px); }
  }

  .mobile-ctas {
    display: none;
    z-index: 20;
  }
  .mobile-ctas a {
    font-family: var(--serif-jp);
    font-weight: 400;
    color: var(--ink);
    background: rgba(11,20,25,0.7);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }
  .mobile-ctas a.primary { background: rgba(156,199,212,0.95); color: var(--deep); }

  @media (max-width: 640px) {
    .vguests { display: none; }
    .ctas { display: none; }
    .sns { display: none; }
    .bottombar { display: none; }

    .mobile-ctas {
      display: flex;
      flex-direction: column;
      position: fixed;
      left: 0;
      bottom: 24px;
      top: auto;
      right: auto;
      width: auto;
      z-index: 30;
      gap: 0;
      transition: opacity 0.5s ease, transform 0.5s ease;
      transform-origin: left bottom;
    }
    .mobile-ctas.cta-compact {
      opacity: 0;
      pointer-events: none;
      transform: translateX(-100%);
    }
    .mobile-ctas a {
      width: 38px;
      height: 120px;
      flex: none;
      padding: 0;
      display: flex; align-items: center; justify-content: center;
      border: none;
      writing-mode: vertical-rl;
      text-orientation: mixed;
      font-family: var(--serif-jp);
      font-weight: 400;
      font-size: 12px;
      letter-spacing: 0.3em;
      color: var(--ink);
      background: rgba(11, 20, 25, 0.85);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      border-radius: 0 2px 2px 0;
      transition: background 0.3s ease;
    }
    .mobile-ctas a + a {
      border-top: 1px solid rgba(255,255,255,0.1);
    }
    .mobile-ctas a.primary {
      background: rgba(156, 199, 212, 0.92);
      color: var(--deep);
    }
    .mobile-ctas a:active { background: rgba(11, 20, 25, 0.92); }
    .mobile-ctas a.primary:active { background: rgba(156, 199, 212, 1); }
  }

  @media (prefers-reduced-motion: reduce) {
    .ctas, .mobile-ctas { transition: opacity 0.2s ease; }
    .ctas.cta-compact { transform: translateY(-50%); }
    .mobile-ctas.cta-compact { transform: none; }
  }
</style>
