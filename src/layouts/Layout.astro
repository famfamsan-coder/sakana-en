---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = '東京都西多摩郡日の出町、平井川のほとり。渓流釣り、つかみ捕り、バーベキューなど自然と触れ合う体験をお楽しみいただけます。' } = Astro.props;
---

<!doctype html>
<html lang="ja" data-lang="ja">
<head>
  <meta charset="utf-8" />
  <script is:inline>
    (function(){var l=localStorage.getItem('sakana-lang')||'ja';document.documentElement.setAttribute('data-lang',l)})();
  </script>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@300;400;500;600&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300&family=Inter:wght@300;400;500&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet" />
</head>
<body>
  <slot />
</body>
</html>
